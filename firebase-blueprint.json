{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Society": {
      "title": "Society",
      "description": "Cooperative society details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "currency": { "type": "string" },
        "admins": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "name", "admins", "createdAt"]
    },
    "Member": {
      "title": "Member",
      "description": "A member of a society",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "societyId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "dob": { "type": "string" },
        "aadharNo": { "type": "string" },
        "panNo": { "type": "string" },
        "phone": { "type": "string" },
        "joinedAt": { "type": "integer" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdByName": { "type": "string" },
        "updatedByName": { "type": "string" }
      },
      "required": ["id", "societyId", "name", "email", "role", "status", "joinedAt"]
    },
    "Income": {
      "title": "Income",
      "description": "Logged income in a society",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "createdByName": { "type": "string" }
      },
      "required": ["source", "amount", "category", "date", "createdAt", "createdBy"]
    },
    "Task": {
      "title": "Task",
      "description": "A task in the society's kanban/todo system",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "integer" },
        "societyId": { "type": "string" },
        "createdByName": { "type": "string" },
        "updatedByName": { "type": "string" }
      },
      "required": ["title", "status", "priority", "createdAt", "societyId"]
    },
    "RecurringTemplate": {
      "title": "Recurring Template",
      "description": "Template for repeating expenses",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "paidBy": { "type": "string" },
        "date": { "type": "string" },
        "splitType": { "type": "string" },
        "splits": { "type": "array" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "frequency": { "type": "string" },
        "nextExecutionDate": { "type": "integer" },
        "active": { "type": "boolean" }
      },
      "required": ["description", "amount", "frequency", "nextExecutionDate", "active"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Logged expense in a society",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "societyId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "paidBy": { "type": "string" },
        "date": { "type": "string" },
        "splitType": { "type": "string", "enum": ["equal", "percentage", "custom", "shares"] },
        "splits": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "memberId": { "type": "string" },
              "amount": { "type": "number" },
              "percentage": { "type": "number" }
            }
          } 
        },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "createdByName": { "type": "string" },
        "updatedByName": { "type": "string" }
      }
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "sharePrice": { "type": "number" },
        "monthlySpentTarget": { "type": "number" },
        "updatedAt": { "type": "integer" },
        "updatedByName": { "type": "string" }
      },
      "required": ["sharePrice", "updatedAt"]
    },
    "ShareTransaction": {
      "title": "Share Transaction",
      "description": "Audit log for share changes",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "previousUnits": { "type": "number" },
        "newUnits": { "type": "number" },
        "change": { "type": "number" },
        "reason": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdByName": { "type": "string" }
      },
      "required": ["memberId", "memberName", "change", "createdAt"]
    },
    "OnboardingRecord": {
      "title": "Onboarding Record",
      "description": "Potential members in the boarding queue",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "suggestedRole": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "dob": { "type": "string" },
        "aadharNo": { "type": "string" },
        "panNo": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdByName": { "type": "string" }
      },
      "required": ["name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/societies/{societyId}": {
      "schema": "Society",
      "description": "Societies collection"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Global members collection for the cooperative"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Global expenses collection"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks collection"
    },
    "/recurring_templates/{templateId}": {
      "schema": "RecurringTemplate",
      "description": "Recurring expense templates"
    },
    "/incomes/{incomeId}": {
      "schema": "Income",
      "description": "Incomes collection"
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global settings"
    },
    "/share_transactions/{transId}": {
      "schema": "ShareTransaction",
      "description": "Share transaction history"
    },
    "/onboarding/{recordId}": {
      "schema": "OnboardingRecord",
      "description": "Member onboarding queue"
    }
  }
}
