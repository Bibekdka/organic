rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'paidBy', 'splitType', 'createdAt', 'createdBy', 'category', 'date', 'splits', 'isRecurring']) &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string &&
             data.splits is list &&
             data.splitType in ['equal', 'percentage', 'custom', 'shares'] &&
             data.createdBy == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'createdAt', 'societyId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['todo', 'in_progress', 'done'] &&
             data.priority in ['low', 'medium', 'high'] &&
             data.createdAt is number &&
             data.societyId is string;
    }

    function isValidRecurringTemplate(data) {
      return data.keys().hasAll(['description', 'amount', 'frequency', 'nextExecutionDate', 'active', 'category', 'paidBy', 'splitType', 'date', 'splits', 'isRecurring', 'createdAt', 'createdBy']) &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number && data.amount >= 0 &&
             data.frequency in ['daily', 'weekly', 'monthly', 'yearly'] &&
             data.nextExecutionDate is number &&
             data.active is bool &&
             data.createdBy == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /expenses/{expenseId} {
      // Allow any signed in user to read for now (community app)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isSignedIn() && (existing().createdBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().createdBy == request.auth.uid || isAdmin());
    }

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Society members can manage membership for now
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'assignedTo', 'title', 'description'])
      );
      allow delete: if isSignedIn();
    }

    match /recurring_templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecurringTemplate(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['active', 'nextExecutionDate', 'description', 'amount'])
      );
      allow delete: if isSignedIn();
    }

    match /test/connection {
      allow read: if true;
    }

    // Admin lookup helper
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
