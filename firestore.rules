rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'paidBy', 'splitType', 'category', 'date', 'splits']) &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string &&
             data.splits is list &&
             data.splitType in ['equal', 'percentage', 'custom', 'shares'] &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string) &&
             (!data.keys().hasAny(['updatedByName']) || data.updatedByName is string);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'createdAt', 'societyId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['todo', 'in_progress', 'done'] &&
             data.priority in ['low', 'medium', 'high'] &&
             data.createdAt is number &&
             data.societyId is string &&
             (!data.keys().hasAny(['assignedTo']) || data.assignedTo is string || data.assignedTo == null) &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string) &&
             (!data.keys().hasAny(['updatedByName']) || data.updatedByName is string);
    }

    function isValidIncome(data) {
      return data.keys().hasAll(['source', 'amount', 'category', 'date']) &&
             data.source is string && data.source.size() <= 200 &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is number || data.createdAt is timestamp) &&
             (!data.keys().hasAny(['createdBy']) || data.createdBy is string) &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string) &&
             (!data.keys().hasAny(['notes']) || data.notes is string) &&
             (!data.keys().hasAny(['submittedToBank']) || data.submittedToBank is bool) &&
             (!data.keys().hasAny(['updatedBy']) || data.updatedBy is string) &&
             (!data.keys().hasAny(['updatedAt']) || data.updatedAt is number || data.updatedAt is timestamp);
    }

    function isValidRecurringTemplate(data) {
      return data.keys().hasAll(['description', 'amount', 'frequency', 'nextExecutionDate', 'active', 'category', 'paidBy', 'splitType', 'date', 'splits']) &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number && data.amount >= 0 &&
             data.frequency in ['daily', 'weekly', 'monthly', 'yearly'] &&
             data.nextExecutionDate is number &&
             data.active is bool;
    }
    
    function isValidAppSettings(data) {
      return data.keys().hasAll(['sharePrice', 'updatedAt']) &&
             data.sharePrice is number && data.sharePrice >= 0 &&
             data.updatedAt is number &&
             (!data.keys().hasAny(['updatedByName']) || data.updatedByName is string);
    }
    
    function isValidShareTransaction(data) {
      return data.keys().hasAll(['memberId', 'memberName', 'change', 'createdAt']) &&
             data.memberId is string &&
             data.memberName is string &&
             data.change is number &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string);
    }

    function isValidOnboarding(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             (!data.keys().hasAny(['email']) || data.email is string) &&
             (!data.keys().hasAny(['gender']) || data.gender in ['male', 'female', 'other']) &&
             (!data.keys().hasAny(['dob']) || data.dob is string) &&
             (!data.keys().hasAny(['aadharNo']) || data.aadharNo is string) &&
             (!data.keys().hasAny(['panNo']) || data.panNo is string) &&
             (!data.keys().hasAny(['phone']) || data.phone is string) &&
             (!data.keys().hasAny(['suggestedRole']) || data.suggestedRole is string) &&
             (!data.keys().hasAny(['notes']) || data.notes is string) &&
             (!data.keys().hasAny(['shares']) || data.shares is number) &&
             (!data.keys().hasAny(['status']) || data.status is string) &&
             (!data.keys().hasAny(['createdBy']) || data.createdBy is string) &&
             (!data.keys().hasAny(['createdByDevice']) || data.createdByDevice is string) &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string) &&
             (!data.keys().hasAny(['updatedByName']) || data.updatedByName is string) &&
             (!data.keys().hasAny(['updatedByDevice']) || data.updatedByDevice is string) &&
             (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp);
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------

    function isValidMember(data) {
      return data.keys().hasAll(['name', 'role', 'status', 'joinedAt', 'shares', 'avatarUrl']) &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['admin', 'member', 'president', 'secretary', 'promoter'] &&
             data.status in ['active', 'inactive'] &&
             data.shares is number &&
             (!data.keys().hasAny(['email']) || data.email is string) &&
             (!data.keys().hasAny(['gender']) || data.gender in ['male', 'female', 'other']) &&
             (!data.keys().hasAny(['dob']) || data.dob is string) &&
             (!data.keys().hasAny(['aadharNo']) || data.aadharNo is string) &&
             (!data.keys().hasAny(['panNo']) || data.panNo is string) &&
             (!data.keys().hasAny(['phone']) || data.phone is string) &&
             (!data.keys().hasAny(['createdByName']) || data.createdByName is string) &&
             (!data.keys().hasAny(['updatedByName']) || data.updatedByName is string);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /expenses/{expenseId} {
      // Allow any signed in user to read for now (community app)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidExpense(incoming()) && (!incoming().keys().hasAny(['createdBy']) || incoming().createdBy == request.auth.uid);
      allow update: if isSignedIn() && isValidExpense(incoming()) && 
                     (!existing().keys().hasAny(['createdBy']) || existing().createdBy == null || incoming().createdBy == existing().createdBy || isAdmin()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'paidBy', 'category', 'date', 'splits', 'splitType', 'isRecurring', 'updatedAt', 'updatedByName', 'updatedByDevice']);
      allow delete: if isSignedIn();
    }

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMember(incoming());
      allow update: if isSignedIn() && (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'name', 'email', 'status', 'shares', 'avatarUrl', 'gender', 'dob', 'aadharNo', 'panNo', 'phone', 'updatedAt', 'updatedByName', 'updatedByDevice']));
      allow delete: if isSignedIn();
    }

    match /onboarding/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOnboarding(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'email', 'suggestedRole', 'gender', 'dob', 'aadharNo', 'panNo', 'phone', 'notes', 'shares', 'updatedByName', 'updatedByDevice', 'updatedAt'
        ])
      );
      allow delete: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'assignedTo', 'title', 'description', 'updatedAt', 'updatedByName', 'updatedByDevice'])
      );
      allow delete: if isSignedIn();
    }

    match /recurring_templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecurringTemplate(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['active', 'nextExecutionDate', 'description', 'amount', 'frequency', 'category', 'paidBy', 'splitType', 'date', 'splits', 'isRecurring', 'updatedAt', 'updatedByName', 'updatedByDevice'])
      );
      allow delete: if isSignedIn();
    }

    match /incomes/{incomeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidIncome(incoming()) && (!incoming().keys().hasAny(['createdBy']) || incoming().createdBy == request.auth.uid);
      allow update: if isSignedIn() && isValidIncome(incoming()) && 
                     (!existing().keys().hasAny(['createdBy']) || existing().createdBy == null || incoming().createdBy == existing().createdBy || isAdmin()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['source', 'amount', 'category', 'date', 'notes', 'submittedToBank', 'updatedAt', 'updatedBy', 'updatedByName', 'updatedByDevice']);
      allow delete: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // For now anyone can update for demo, ideally isAdmin()
    }

    match /share_transactions/{transId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidShareTransaction(incoming());
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    match /test/connection {
      allow read: if true;
    }

    // Admin lookup helper
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
