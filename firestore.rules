rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'paidBy', 'splitType', 'createdAt', 'userId']) &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number && data.amount >= 0 &&
             data.splitType in ['equal', 'percentage', 'custom', 'shares'] &&
             data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /expenses/{expenseId} {
      // Allow any signed in user to read for now (community app)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isSignedIn() && (existing().createdBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().createdBy == request.auth.uid || isAdmin());
    }

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Society members can manage membership for now
    }

    match /test/connection {
      allow read: if true;
    }

    // Admin lookup helper
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
